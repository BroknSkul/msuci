<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer Faint Glow -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#15C88691" />
            <corners android:radius="32dp" />
        </shape>
    </item>
    <!-- Middle Soft Glow -->
    <item android:left="1.5dp" android:top="1.5dp" android:right="1.5dp" android:bottom="1.5dp">
        <shape android:shape="rectangle">
            <solid android:color="#35C88691" />
            <corners android:radius="31dp" />
        </shape>
    </item>
    <!-- Inner Strong Glow -->
    <item android:left="3dp" android:top="3dp" android:right="3dp" android:bottom="3dp">
        <shape android:shape="rectangle">
            <solid android:color="#60C88691" />
            <corners android:radius="30dp" />
        </shape>
    </item>
    <!-- Main Background and Primary Border -->
    <item android:left="4.5dp" android:top="4.5dp" android:right="4.5dp" android:bottom="4.5dp">
        <shape android:shape="rectangle">
            <solid android:color="#F2000000" />
            <corners android:radius="29dp" />
            <stroke
                android:width="2.5dp"
                android:color="#FFC88691" />
        </shape>
    </item>
</layer-list>